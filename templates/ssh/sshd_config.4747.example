# ==============================================================================
# sshd_config.4747.example
# Secure SSH template using port 4747
# Placeholders:
#   __ADMIN_USER__
#   __BOOTSTRAP_USER__
# ==============================================================================

# --- Network ---
Port 4747
Protocol 2

# --- Authentication defaults ---
PermitRootLogin no
PasswordAuthentication no
KbdInteractiveAuthentication no
ChallengeResponseAuthentication no
PubkeyAuthentication yes
AuthorizedKeysFile %h/.ssh/authorized_keys
UsePAM yes

# --- Session / login behavior ---
LoginGraceTime 30
PrintMotd no
PrintLastLog yes
TCPKeepAlive yes
X11Forwarding no

# --- Forwarding / tunneling ---
AllowTcpForwarding yes
AllowStreamLocalForwarding yes
GatewayPorts no

# Uncomment only if you explicitly need them
# PermitTunnel yes
# PermitOpen any

# --- Limit allowed SSH users ---
AllowUsers __ADMIN_USER__ __BOOTSTRAP_USER__

# --- Temporary fallback for bootstrap user ---
Match User __BOOTSTRAP_USER__
    PasswordAuthentication yes
    KbdInteractiveAuthentication yes

# --- Subsystem ---
Subsystem sftp /usr/lib/openssh/sftp-server
