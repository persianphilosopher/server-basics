# ==============================================================================
# sshd_config.4747.example — Secure SSH server config using custom port
# Intended as a template — must be manually audited before use
# ==============================================================================

Port 4747
Protocol 2

# Strong key-based auth only
PermitRootLogin prohibit-password
PasswordAuthentication no
ChallengeResponseAuthentication no
PubkeyAuthentication yes
AuthorizedKeysFile %h/.ssh/authorized_keys

# Connection and login behavior
LoginGraceTime 30
PrintMotd no
PrintLastLog yes
TCPKeepAlive yes
UsePAM yes
X11Forwarding no

# Tunneling & port forwarding (customize to need)
AllowTcpForwarding yes
PermitTunnel yes
PermitOpen any
GatewayPorts no
AllowStreamLocalForwarding yes

# Subsystem
Subsystem sftp /usr/lib/openssh/sftp-server

# === Reminder ===
# To use this template:
# sudo cp sshd_config.4747.example /etc/ssh/sshd_config
# sudo systemctl restart ssh
# Ensure port 4747 is open in your firewall
