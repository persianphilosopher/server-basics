#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"

echo "server-basics init"
echo "Repo root: $REPO_ROOT"
echo

required_paths=(
  "$REPO_ROOT/config"
  "$REPO_ROOT/scripts"
  "$REPO_ROOT/shell"
)

for path in "${required_paths[@]}"; do
  if [[ ! -e "$path" ]]; then
    echo "Missing required path: $path" >&2
    exit 1
  fi
done

if [[ ! -x "$SCRIPT_DIR/install-packages" ]]; then
  echo "Missing executable: scripts/install-packages" >&2
  exit 1
fi

if [[ ! -x "$SCRIPT_DIR/setup-shell" ]]; then
  echo "Missing executable: scripts/setup-shell" >&2
  exit 1
fi

read -r -p "Install baseline packages? [Y/n] " INSTALL_PKGS
INSTALL_PKGS="${INSTALL_PKGS:-Y}"

if [[ "$INSTALL_PKGS" =~ ^[Yy]$ ]]; then
  sudo "$SCRIPT_DIR/install-packages"
else
  echo "Skipping package installation."
fi

echo
read -r -p "Set up shell environment? [Y/n] " SETUP_SHELL
SETUP_SHELL="${SETUP_SHELL:-Y}"

if [[ "$SETUP_SHELL" =~ ^[Yy]$ ]]; then
  "$SCRIPT_DIR/setup-shell"
else
  echo "Skipping shell setup."
fi

echo
echo "Init complete."
echo
echo "Suggested next steps:"
echo "  1. Log out and back in to test shell setup"
echo "  2. Run: source ~/.bashrc"
echo "  3. Review templates/ssh/sshd_config.4747.example before hardening SSH"
echo "  4. Review templates/caddy/ if you want to install Caddy"
