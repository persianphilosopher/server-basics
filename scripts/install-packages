#!/usr/bin/env bash
set -euo pipefail

read -r -p "Install baseline packages? [Y/n] " reply
reply="${reply:-Y}"

if [[ ! "$reply" =~ ^[Yy]$ ]]; then
  echo "Aborted."
  exit 0
fi

if [[ "${EUID}" -ne 0 ]]; then
  echo "Run this script as root." >&2
  exit 1
fi

PACKAGES=(
  git
  curl
  nano
  unzip
  zip
  tree
  htop
  bash-completion
  ca-certificates
  gnupg
  lsb-release
  software-properties-common
  build-essential
  p7zip-full
  xz-utils
  dos2unix
  rename
  man-db
  rsync
  ufw
)

echo "Updating package lists..."
apt-get update

echo "Installing packages..."
apt-get install -y "${PACKAGES[@]}"

echo "Package installation complete."
