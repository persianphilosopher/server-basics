#!/usr/bin/env bash
set -euo pipefail

if [[ "${EUID}" -ne 0 ]]; then
  echo "Run this script as root." >&2
  exit 1
fi

PACKAGES=(
  git
  curl
  wget
  nano
  unzip
  zip
  tree
  htop
  bash-completion
  ca-certificates
  gnupg
  lsb-release
  build-essential
  p7zip-full
  xz-utils
  dos2unix
  bind9-dnsutils
  rename
  man-db
  rsync
  ufw
)

echo "Updating package lists..."
apt-get update

echo "Installing packages..."
apt-get install -y "${PACKAGES[@]}"

echo "Package installation complete."
